# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/incidentiq?schema=public"

# Server
PORT=4000
NODE_ENV=development

# CORS - frontend origin
CLIENT_ORIGIN="http://localhost:5173"

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Open-source LLM (OpenAI-compatible /chat/completions) ---
# Leave LLM_BASE_URL empty to use the built-in rule-based fallback.
#
# Groq (free, hosted open models):
#   LLM_BASE_URL="https://api.groq.com/openai/v1"
#   LLM_API_KEY="gsk_..."
#   LLM_MODEL="llama-3.3-70b-versatile"
#
# Ollama (fully local / open source — `ollama run llama3.1`):
#   LLM_BASE_URL="http://localhost:11434/v1"
#   LLM_API_KEY=""
#   LLM_MODEL="llama3.1"
LLM_BASE_URL=""
LLM_API_KEY=""
LLM_MODEL="llama-3.3-70b-versatile"
